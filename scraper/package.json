{
  "name": "scraper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PriceWise scraping service (Crawlee + Playwright) exposed over a small HTTP API",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "install:browser": "playwright install chromium"
  },
  "dependencies": {
    "crawlee": "^3.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
