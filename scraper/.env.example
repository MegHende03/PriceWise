# Port the scraper HTTP API listens on
PORT=4000

# Proxies are OPTIONAL. Leaving this empty scrapes from your own IP, which is the right
# choice for low-volume tracking (a tracker's "proxyEnabled" flag is then a no-op).
# Only add proxies for high volume or a site that persistently blocks you, and prefer
# residential rotating proxies over datacenter ones. Comma-separated; a single rotating
# gateway URL is typical. See the root README "Avoiding IP blocks" for the full rationale.
# Example: PROXY_URLS=http://user:pass@gateway.provider.com:7777
PROXY_URLS=

# Crawlee log level: DEBUG, INFO, WARNING, ERROR, OFF
CRAWLEE_LOG_LEVEL=WARNING
